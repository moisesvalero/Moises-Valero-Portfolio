{
	"name": "moisesvalero-portfolio",
	"private": true,
	"version": "0.0.1",
	"license": "PolyForm-Noncommercial-1.0.0",
	"packageManager": "pnpm@10.24.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:vercel": "node scripts/vercel-build.mjs",
		"build:studio": "sanity build",
		"preview": "vite preview",
		"prepare": "husky",
		"format": "prettier --write \"*.{js,ts,json,html}\" \"src/**/*.{js,ts,svelte,css,json}\" \"sanity/**/*.{js,ts}\"",
		"format:check": "prettier --check \"*.{js,ts,json,html}\" \"src/**/*.{js,ts,svelte,css,json}\" \"sanity/**/*.{js,ts}\"",
		"lint": "oxlint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\" --watch",
		"test": "node --test src/lib/server/*.test.ts",
		"studio": "npx sanity dev",
		"sanity:deploy": "sanity deploy",
		"sanity:migrate-home-locale": "sanity exec sanity/migrate-home-locale-safe.ts --with-user-token",
		"sanity:patch-portfolio": "sanity exec sanity/patch-portfolio-copy-i18n-safe.ts --with-user-token",
		"dns:sync": "zsh scripts/sync-moisesvalero-dns.sh"
	},
	"lint-staged": {
		"*.{ts,js,svelte}": [
			"oxlint",
			"prettier --write"
		]
	},
	"devDependencies": {
		"@sanity/cli": "^7.4.0",
		"@sanity/orderable-document-list": "^2.0.4",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^25.9.3",
		"esm-env": "1.2.2",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"oxlint": "^0.15.11",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"sanity": "^6.2.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"vercel": "^54.18.1",
		"vite": "^8.1.3"
	},
	"dependencies": {
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/material-symbols-outlined": "^5.2.45",
		"@sanity/client": "^7.22.0",
		"@sanity/image-url": "^2.1.1",
		"@sparticuz/chromium": "148.0.0",
		"@vercel/analytics": "^2.0.1",
		"clsx": "^2.1.1",
		"gsap": "^3.15.0",
		"node-html-parser": "^6.1.13",
		"ogl": "^1.0.11",
		"playwright-core": "1.60.0",
		"rxjs": "^7.8.2",
		"styled-components": "^6.4.3",
		"tailwind-merge": "^3.6.0"
	}
}
