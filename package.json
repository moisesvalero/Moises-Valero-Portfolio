{
	"name": "novakit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\" --watch",
		"studio": "npx sanity dev"
	},
	"devDependencies": {
		"@iconify/svelte": "^5.2.1",
		"@sanity/cli": "^6.2.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"jsdom": "^29.0.1",
		"sanity": "^5.17.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@sanity/client": "^7.20.0",
		"@sanity/image-url": "^2.0.3",
		"@vercel/analytics": "^2.0.1",
		"styled-components": "^6.3.12"
	}
}
