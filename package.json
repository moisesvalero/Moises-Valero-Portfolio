{
	"name": "moisesvalero-portfolio",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\"",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --compiler-warnings \"css_unused_selector:ignore,slot_element_deprecated:ignore\" --watch",
		"studio": "npx sanity dev",
		"sanity:patch-og": "sanity exec sanity/patch-og-image.ts --with-user-token",
		"sanity:clone-landing-national": "sanity exec sanity/clone-landing-diseno-web.ts --with-user-token",
		"sanity:hero-marquee": "sanity exec sanity/seed-hero-marquee.ts --with-user-token",
		"sanity:seed-support-articles": "sanity exec sanity/seed-landing-support-articles.ts --with-user-token"
	},
	"devDependencies": {
		"@iconify/svelte": "^5.2.1",
		"@sanity/cli": "^6.2.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"jsdom": "^29.0.1",
		"sanity": "^5.18.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource/material-symbols-outlined": "^5.2.39",
		"@sanity/client": "^7.20.0",
		"@sanity/image-url": "^2.1.0",
		"@vercel/analytics": "^2.0.1",
		"styled-components": "^6.3.12"
	}
}
