PUBLIC_SITE_URL=https://tu-dominio.com

# Google Analytics 4: el script solo se inyecta si el visitante pulsa «Aceptar todas» en cookies.
# Crea la propiedad en https://analytics.google.com/ y copia el ID tipo G-XXXXXXXXXX
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# WhatsApp: el endpoint /api/contact/whatsapp gestiona la redirección en servidor.
# Si vuelves a usar variable de entorno para el número, define WHATSAPP_E164 en tu .env local/hosting.
# WHATSAPP_E164=34627950559

# Sanity (web + Studio). Sin estas variables la web usa solo datos locales en src/lib/data/site-portfolio-defaults.ts y case-studies.ts
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_READ_TOKEN=  (necesario en producción si el CV se sube en Sanity y el CDN devuelve 403 al proxy /api/cv)
# SANITY_WRITE_TOKEN=
# Opcional para `npm run studio` si quieres otros nombres que .env del proyecto:
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
# URL pública del Studio autoalojado (registro externo con sanity:register-external):
# SANITY_STUDIO_HOST=https://admin.moisesvalero.es

# Analizador web propio.
# Opcional: limites defensivos para evitar abuso del endpoint.
# WEB_AUDIT_MAX_CALLS_PER_DAY=250
# WEB_AUDIT_RATE_LIMIT_PER_HOUR=15

# Opcional para enviar el informe del analizador por email (/api/web-audit/lead).
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=info@tu-dominio.com
# CONTACT_FROM_EMAIL=Web <onboarding@resend.dev>

# IndexNow (Bing y otros motores compatibles): notifica URLs nuevas/actualizadas.
# 1) Genera una key (ej. UUID) y configúrala en INDEXNOW_KEY.
# 2) Añade INDEXNOW_SUBMIT_TOKEN para proteger el endpoint interno /api/indexnow/submit.
# INDEXNOW_KEY=
# INDEXNOW_SUBMIT_TOKEN=

# Webhook Sanity -> IndexNow (automático al publicar/actualizar artículos)
# Configura este token también en la cabecera del webhook de Sanity:
# x-webhook-token: <SANITY_WEBHOOK_TOKEN>
# SANITY_WEBHOOK_TOKEN=

# i18n (sin variable de entorno): idioma por defecto **español** (SEO y primera visita). Inglés solo si el usuario
# elige en el header (cookie httpOnly `portfolio_locale`). `depends('app:locale')` re-ejecuta el load / Sanity.
# Capa EN de UI: `src/lib/data/site-portfolio-locale-en.ts` (el documento `seo` sigue en español).
