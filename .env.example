PUBLIC_SITE_URL=https://tu-dominio.com

# Google Analytics 4: el script solo se inyecta si el visitante pulsa «Aceptar todas» en cookies.
# Crea la propiedad en https://analytics.google.com/ y copia el ID tipo G-XXXXXXXXXX
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# WhatsApp: el endpoint /api/contact/whatsapp gestiona la redirección en servidor.
# Si vuelves a usar variable de entorno para el número, define WHATSAPP_E164 en tu .env local/hosting.
# WHATSAPP_E164=346XXXXXXXX

# Sanity (web + Studio). Sin estas variables la web usa solo datos locales en src/lib/data/site-portfolio-defaults.ts y case-studies.ts
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_VERSION=2024-01-01
# SANITY_READ_TOKEN=
# Opcional para `npm run studio` si quieres otros nombres que .env del proyecto:
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production

# i18n (sin variable de entorno): idioma por defecto **español** (SEO y primera visita). Inglés solo si el usuario
# elige en el header (cookie httpOnly `portfolio_locale`). `depends('app:locale')` re-ejecuta el load / Sanity.
# Capa EN de UI: `src/lib/data/site-portfolio-locale-en.ts` (el documento `seo` sigue en español).
