{
	"installCommand": "pnpm install --frozen-lockfile",
	"buildCommand": "pnpm run build:vercel",
	"devCommand": "pnpm run dev",
	"build": {
		"env": {
			"NODE_ENV": "production"
		}
	},
	"redirects": [
		{
			"source": "/chat",
			"destination": "/proyectos/chatbot",
			"permanent": true
		},
		{
			"source": "/chat/",
			"destination": "/proyectos/chatbot",
			"permanent": true
		},
		{
			"source": "/ember-iron",
			"destination": "/proyectos/ember-iron",
			"permanent": true
		},
		{
			"source": "/ember-iron/",
			"destination": "/proyectos/ember-iron",
			"permanent": true
		},
		{
			"source": "/galer",
			"destination": "/proyectos/galeria-nova",
			"permanent": true
		},
		{
			"source": "/galer/",
			"destination": "/proyectos/galeria-nova",
			"permanent": true
		},
		{
			"source": "/vshield",
			"destination": "/proyectos/vshield",
			"permanent": true
		},
		{
			"source": "/vshield/",
			"destination": "/proyectos/vshield",
			"permanent": true
		},
		{
			"source": "/ember",
			"destination": "https://ember.moisesvalero.es",
			"permanent": true
		},
		{
			"source": "/ember/",
			"destination": "https://ember.moisesvalero.es",
			"permanent": true
		},
		{
			"source": "/v-shield",
			"destination": "https://v-shield.moisesvalero.es",
			"permanent": true
		},
		{
			"source": "/v-shield/",
			"destination": "https://v-shield.moisesvalero.es",
			"permanent": true
		}
	]
}
